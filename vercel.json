{
  "rewrites": [
    { "source": "/ping",                              "destination": "/api/ping" },
    { "source": "/contact",                           "destination": "/api/contact" },
    { "source": "/analytics",                         "destination": "/api/analytics" },
    { "source": "/upload",                            "destination": "/api/upload" },
    { "source": "/save-config",                       "destination": "/api/save-config" },
    { "source": "/timelog",                           "destination": "/api/timelog" },
    { "source": "/timelog/:path*",                    "destination": "/api/timelog" },
    { "source": "/config-data",                       "destination": "/api/config" },
    { "source": "/media-proxy",                       "destination": "/api/media" },
    { "source": "/api/clients",                       "destination": "/api/billing" },
    { "source": "/api/clients/:id",                   "destination": "/api/billing" },
    { "source": "/api/documents",                     "destination": "/api/billing" },
    { "source": "/api/documents/:id",                 "destination": "/api/billing" },
    { "source": "/api/documents/:id/convert",         "destination": "/api/billing" }
  ],
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
