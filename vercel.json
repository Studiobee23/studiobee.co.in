{
  "rewrites": [
    { "source": "/ping",        "destination": "/api/ping" },
    { "source": "/contact",     "destination": "/api/contact" },
    { "source": "/analytics",   "destination": "/api/analytics" },
    { "source": "/upload",      "destination": "/api/upload" },
    { "source": "/save-config", "destination": "/api/save-config" },
    { "source": "/config-data", "destination": "/api/config" },
    { "source": "/media-proxy", "destination": "/api/media" }
  ],
  "functions": {
    "api/**/*.js":              { "maxDuration": 10 },
    "api/generate-pdf.js":      { "maxDuration": 60, "memory": 1024 },
    "api/send-email.js":        { "maxDuration": 60, "memory": 1024 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
