# Local dev environment — copy this file to .env and fill in real values
# .env is gitignored and never committed

PORT=3000
ADMIN_KEY=your-admin-key-here

# SMTP — email delivery for the contact form
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@studiobee.ai
SMTP_PASS=your-app-password-here
SMTP_TO=arora.nikhil@studiobee.ai
SMTP_FROM=studiobee Website <your-email@studiobee.ai>

# Supabase — used by Vercel API functions (not needed for local serve.mjs)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
